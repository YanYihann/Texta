// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String @id
  email        String @unique
  name         String
  passwordHash String
  role         String @default("user")
  plan         String @default("free")
  createdAt    String
}

model Session {
  token     String @id
  userId    String
  expiresAt BigInt
  createdAt BigInt

  @@index([userId])
}

model UsageDaily {
  id      String @id @default(cuid())
  userId  String
  dateKey String
  used    Int    @default(0)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model UsageLog {
  id          String @id @default(cuid())
  userId      String
  usedAt      String
  dateKey     String
  hourKey     String
  periodLabel String

  @@index([userId, usedAt])
  @@index([hourKey])
}

model VipRequest {
  id            String @id
  userId        String
  userEmail     String
  payerName     String
  amount        String
  paidAt        String
  proofCode     String
  proofImageUrl String
  note          String
  status        String
  createdAt     String
  reviewedAt    String
  reviewerId    String
  reviewNote    String

  @@index([userId, status])
}

model FavoriteArticle {
  id           String @id
  userId       String
  title        String
  savedAt      String
  words        Json
  article      String
  lexicon      Json
  paragraphsEn Json
  paragraphsZh Json
  alignment    Json
  missing      Json
  createdAt    String
  updatedAt    String

  @@index([userId, updatedAt])
  @@index([userId, savedAt])
}

model NotebookEntry {
  id           String @id @default(cuid())
  userId       String
  wordKey      String
  word         String
  pos          String
  senses       Json
  collocations Json
  synonyms     Json
  antonyms     Json
  wordFormation String
  createdAt    String
  updatedAt    String

  @@unique([userId, wordKey])
  @@index([userId, updatedAt])
}

model UserVocabPref {
  id        String @id @default(cuid())
  userId    String
  wordKey   String
  word      String
  mastery   String
  createdAt String
  updatedAt String

  @@unique([userId, wordKey])
  @@index([userId, updatedAt])
}
